STRIPE_PRO_PRICE_ID=price_...

# App config
FRONTEND_URL=http://localhost:3000
MAX_JD_LENGTH=8000
FREE_TIER_SESSION_LIMIT=3
PRO_TIER_SESSION_LIMIT=50
SESSION_TIMEOUT_MINUTES=5
