# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/resyncc

# Auth
JWT_SECRET=minimum-32-character-secret-key-here
JWT_EXPIRY_HOURS=24
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_ANON_KEY=ey...

# Groq (free)
GROQ_API_KEY=gsk_...

# Cloudflare R2
R2_ACCESS_KEY_ID=...
